{
	"name": "@dexaf/sagi-style",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Dexaf/sagi-style"
	},
	"license": "UNLICENSED",
	"version": "1.3.2",
	"type": "module",
	"author": "Federico Pisa - Sagitauros",
	"description": "system design for sagitauros studio's inside applications",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/sagi-style.js"
		},
		"./index.css": "./dist/index.css",
		"./assets/*": "./dist/assets/*"
	},
	"scripts": {
		"dev": "vite --host",
		"build-lib-test": "vite build --config vite.config.lib.ts",
		"build-demo": "tsc && vite build --config vite.config.demo.ts",
		"preview": "vite preview",
		"publish-package": "vite build --config vite.config.lib.ts && npm publish --access=public"
	},
	"devDependencies": {
		"@types/node": "^25.7.0",
		"typescript": "~6.0.2",
		"vite": "^8.0.12"
	}
}
